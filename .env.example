# Environment Variables (copy to .env and fill in)

# ── ClickHouse ──
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=market_anomaly

# ── Live Data Provider ──
# Options: "twelvedata" or "simulated"
WS_PROVIDER=simulated

# Twelve Data API Key (get from https://twelvedata.com)
TWELVEDATA_API_KEY=
